-- Comandos basicos em um banco de dados

CREATE DATABASE ESTUDO_BANCO; -- CRIANDO UM NOVO BANCO

-- Temos os comandos de criação, alteração e de excluir
-- CREATE , ALTER E DROPA

CREATE TABLE PRODUTOS (
	ID_PRODUTO INT NOT NULL PRIMARY KEY IDENTITY(1 , 1),
	ID_MARCA INT NOT NULL,
	NOME VARCHAR (100),
	PRECO DECIMAL NOT NULL, -- Decimal ou numeric serve mais para quantidade de dinheiro
	ESTOQUE INT DEFAULT 0

);

--IDENTITY(1 , 1) serve para que o proprio banco entenda que vai incrementar sozinho
--DEFAULT 0 serve para que caso não colque valor o 0 vai ocupar esse espaço


--Essa deve ser criada primeiro para não dar erro
CREATE TABLE MARCAS (
	ID_MARCA INT NOT NULL PRIMARY KEY IDENTITY(1,1),
	NOME VARCHAR (100) NOT NULL UNIQUE, --UNIQUE serve para que o nome não se repita
	SITE VARCHAR (100),
	TELEFONE VARCHAR

);

--Dai precisamos criar nossa chaves estrangeiras
ALTER TABLE PRODUTOS
	ADD CONSTRAINT FK_ID_MARCA FOREIGN KEY (ID_MARCA) REFERENCES MARCAS (ID_MARCA)

